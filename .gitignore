# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# == Node
**/node_modules/
**/jspm_packages/
/.pnp
/.pnp.js
/build
/dist/
/coverage

# Misc:
**/.nyc_output
**/.grunt
**/.lock-wscript
**/.yarn-integrity
**/*.tgz
**/lib-cov
**/bower_components

# Logs:
**/logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.node_repl_history

# Cache:
**/.npm
**/.eslintcache
**/*.tsbuildinfo

# Runtime data:
# **/pids
# **/*.pid
# **/*.seed
# **/*.pid.lock

# == IDE
# VSCode (keeping workspace configurations):
**/.vscode/*
!**/.vscode/tasks.json
!**/.vscode/extensions.json
!**/.vscode/settings.json
#!.vscode/launch.json

# IntelliJ:
**/.idea/


# == OS
# macOS:
**/.DS_Store
**/.DS_Store?
**/*.swp

# Windows:
**/Thumbs.db
