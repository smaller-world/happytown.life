  #   timeout.socket
  # @return [Object] the underlying socket
  #
  # source://http//lib/http/timeout/null.rb#33
  def socket; end

  # Configures the SSL connection and starts it
  #
  # @api public
  # @example
  #   timeout.start_tls("example.com", ssl_class, ssl_ctx)
  # @param host [String]
  # @param ssl_context [OpenSSL::SSL::SSLContext]
  # @param ssl_socket_class [Class]
  # @return [void]
  #
  # source://http//lib/http/timeout/null.rb#110
  def start_tls(host, ssl_socket_class, ssl_context); end

  # Write to the socket
  #
  # @api public
  # @example
  #   timeout.write("GET / HTTP/1.1")
  # @param data [String]
  # @return [Integer]
  #
  # source://http//lib/http/timeout/null.rb#146
  def write(data); end

  private

  # Whether the socket class supports native connect_timeout
  #
  # @api private
  # @param socket_class [Class] socket class to check
  # @return [Boolean]
  #
  # source://http//lib/http/timeout/null.rb#220
  def native_timeout?(socket_class); end

  # Opens a TCP socket, using native connect_timeout when available
  #
  # On Ruby 3.4+ with TCPSocket, passes connect_timeout natively to
  # enable proper Happy Eyeballs (RFC 8305) support. Falls back to
  # Timeout.timeout on older Rubies or with custom socket classes.
  #
  # @api private
  # @param connect_timeout [Numeric, nil] timeout in seconds
  # @param host [String] remote hostname
  # @param port [Integer] remote port
  # @param socket_class [Class] socket class to create
  # @return [Object] the connected socket
  #
  # source://http//lib/http/timeout/null.rb#187
  def open_socket(socket_class, host, port, connect_timeout: T.unsafe(nil)); end

  # Opens a socket, passing connect_timeout natively when supported
  #
  # @api private
  # @param connect_timeout [Numeric] timeout in seconds
  # @param host [String] remote hostname
  # @param port [Integer] remote port
  # @param socket_class [Class] socket class to create
  # @return [Object] the connected socket
  #
  # source://http//lib/http/timeout/null.rb#207
  def open_with_timeout(socket_class, host, port, connect_timeout); end

  # Retries reading on wait readable
  #
  # @api private
  # @return [Object]
  #
  # source://http//lib/http/timeout/null.rb#157
  def rescue_readable(timeout = T.unsafe(nil)); end

  # Retries writing on wait writable
  #
  # @api private
  # @return [Object]
  #
  # source://http//lib/http/timeout/null.rb#168
  def rescue_writable(timeout = T.unsafe(nil)); end
end

# Whether TCPSocket natively supports connect_timeout and
# Happy Eyeballs (RFC 8305). Available in Ruby 3.4+.
#
# @api private
#
# source://http//lib/http/timeout/null.rb#15
HTTP::Timeout::Null::NATIVE_CONNECT_TIMEOUT = T.let(T.unsafe(nil), TrueClass)

# Timeout handler with separate timeouts for connect, read, and write
#
# source://http//lib/http/timeout/per_operation.rb#10
class HTTP::Timeout::PerOperation < ::HTTP::Timeout::Null
  # Initializes per-operation timeout with options
  #
  # @api public
  # @example
  #   HTTP::Timeout::PerOperation.new(read_timeout: 5)
  # @param connect_timeout [Numeric, nil] Connect timeout in seconds (nil for no timeout)
  # @param read_timeout [Numeric, nil] Read timeout in seconds (nil for no timeout)
  # @param write_timeout [Numeric, nil] Write timeout in seconds (nil for no timeout)
  # @return [HTTP::Timeout::PerOperation]
  #
  # source://http//lib/http/timeout/per_operation.rb#85
  def initialize(read_timeout: T.unsafe(nil), write_timeout: T.unsafe(nil), connect_timeout: T.unsafe(nil)); end

  # Connects to a socket with connect timeout
  #
  # @api public
  # @example
  #   timeout.connect(TCPSocket, "example.com", 80)
  # @param host [String]
  # @param nodelay [Boolean]
  # @param port [Integer]
  # @param socket_class [Class]
  # @return [void]
  #
  # source://http//lib/http/timeout/per_operation.rb#104
  def connect(socket_class, host, port, nodelay: T.unsafe(nil)); end

  # Starts an SSL connection with connect timeout
  #
  # @api public
  # @example
  #   timeout.connect_ssl
  # @return [void]
  #
  # source://http//lib/http/timeout/per_operation.rb#116
  def connect_ssl; end

  # Read data from the socket
  #
  # @api public
  # @example
  #   timeout.readpartial(1024)
  # @param buffer [String, nil]
  # @param size [Integer]
  # @return [String, :eof]
  #
  # source://http//lib/http/timeout/per_operation.rb#136
  def readpartial(size, buffer = T.unsafe(nil)); end

  # Write data to the socket
  #
  # @api public
  # @example
  #   timeout.write("GET / HTTP/1.1")
  # @param data [String]
  # @return [Integer]
  #
  # source://http//lib/http/timeout/per_operation.rb#168
  def write(data); end

  private

  # Waits for I/O readiness based on the result type
  #
  # @api private
  # @param result [Symbol] the I/O wait type (:wait_readable or :wait_writable)
  # @param timeout [Numeric, nil] per-operation timeout limit
  # @return [Object, nil] the socket if ready, nil on timeout
  #
  # source://http//lib/http/timeout/per_operation.rb#188
  def wait_for_io(result, timeout); end

  class << self
    # Normalize and validate timeout options
    #
    # @api public
    # @example
    #   PerOperation.normalize_options(read: 5, write: 3)
    # @param options [Hash] timeout options with short or long keys
    # @raise [ArgumentError] if options are invalid
    # @return [Hash] normalized options with long keys
    #
    # source://http//lib/http/timeout/per_operation.rb#23
    def normalize_options(options); end

    private

    # Extract and validate global timeout from options hash
    #
    # @api private
    # @example
    #   extract_global_timeout!({global: 60, read: 5})
    # @param options [Hash] mutable options hash (global key is deleted if found)
    # @raise [ArgumentError] if both forms given or value is not numeric
    # @return [Numeric, nil] the global timeout value, or nil if not present
    #
    # source://http//lib/http/timeout/per_operation.rb#48
    def extract_global_timeout!(options); end

    # Resolve a single timeout value from the options hash
    #
    # @api private
    # @example
    #   resolve_timeout_value!({read: 5}, :read, :read_timeout)
    # @param long [Symbol] long key name (e.g. :read_timeout)
    # @param options [Hash] mutable options hash (keys are deleted as consumed)
    # @param short [Symbol] short key name (e.g. :read)
    # @raise [ArgumentError] if both forms given or value is not numeric
    # @raise [ArgumentError]
    # @return [Numeric] the timeout value
    #
    # source://http//lib/http/timeout/per_operation.rb#65
    def resolve_timeout_value!(options, short, long); end
  end
end

# Mapping of shorthand option keys to their full forms
#
# source://http//lib/http/timeout/per_operation.rb#12
HTTP::Timeout::PerOperation::KEYS = T.let(T.unsafe(nil), Hash)

# I/O wait result symbols returned by non-blocking operations
#
# source://http//lib/http/timeout/per_operation.rb#125
HTTP::Timeout::PerOperation::WAIT_RESULTS = T.let(T.unsafe(nil), Array)

# Generic Timeout error
#
# source://http//lib/http/errors.rb#60
class HTTP::TimeoutError < ::HTTP::Error; end

# HTTP URI with scheme, authority, path, query, and fragment components
#
# Stores URI components as instance variables. Addressable is only used
# when parsing non-ASCII (IRI) strings; ASCII URIs use stdlib's URI.parse.
#
# source://http//lib/http/uri.rb#10
class HTTP::URI
  # Creates an HTTP::URI instance from the given keyword arguments
  #
  # @api public
  # @example
  #   HTTP::URI.new(scheme: "http", host: "example.com")
  # @param fragment [String, nil] component at the end of the URI
  # @param host [String, nil] name component (IPv6 addresses must be bracketed)
  # @param password [String, nil] for basic authentication
  # @param path [String, nil] component to request
  # @param port [Integer, nil] network port to connect to
  # @param query [String, nil] component distinct from path
  # @param scheme [String, nil] URI scheme
  # @param user [String, nil] for basic authentication
  # @return [HTTP::URI] new URI instance
  #
  # source://http//lib/http/uri.rb#127
  def initialize(scheme: T.unsafe(nil), user: T.unsafe(nil), password: T.unsafe(nil), host: T.unsafe(nil), port: T.unsafe(nil), path: T.unsafe(nil), query: T.unsafe(nil), fragment: T.unsafe(nil)); end

  # Are these URI objects equal after normalization
  #
  # @api public
  # @example
  #   HTTP::URI.parse("http://example.com") == HTTP::URI.parse("http://example.com")
  # @param other [Object] URI to compare this one with
  # @return [TrueClass, FalseClass] are the URIs equivalent (after normalization)?
  #
  # source://http//lib/http/uri.rb#150
  def ==(other); end

  # Pattern matching interface
  #
  # @api public
  # @example
  #   uri.deconstruct_keys(%i[scheme host])
  # @param keys [Array<Symbol>, nil] keys to extract, or nil for all
  # @return [Hash{Symbol => Object}]
  #
  # source://http//lib/http/uri.rb#367
  def deconstruct_keys(keys); end

  # Default port for the URI scheme
  #
  # @api public
  # @example
  #   HTTP::URI.parse("http://example.com").default_port # => 80
  # @return [Integer, nil] default port or nil for unknown schemes
  #
  # source://http//lib/http/uri.rb#212
  def default_port; end

  # Duplicates the URI object
  #
  # @api public
  # @example
  #   HTTP::URI.parse("http://example.com").dup
  # @return [HTTP::URI] duplicated URI
  #
  # source://http//lib/http/uri.rb#323
  def dup; end

  # Are these URI objects equal without normalization
  #
  # @api public
  # @example
  #   uri = HTTP::URI.parse("http://example.com")
  #   uri.eql?(HTTP::URI.parse("http://example.com"))
  # @param other [Object] URI to compare this one with
  # @return [TrueClass, FalseClass] are the URIs equivalent?
  #
  # source://http//lib/http/uri.rb#164
  def eql?(other); end

  # URI fragment
  #
  # @api public
  # @example
  #   uri.fragment # => "section1"
  # @return [String, nil] The fragment component
  #
  # source://http//lib/http/uri.rb#84
  def fragment; end

  # Hash value based off the normalized form of a URI
  #
  # @api public
  # @example
  #   HTTP::URI.parse("http://example.com").hash
  # @return [Integer] A hash of the URI
  #
  # source://http//lib/http/uri.rb#175
  def hash; end

  # Host, either a domain name or IP address
  #
  # @api public
  # @example
  #   uri.host # => "example.com"
  # @return [String, nil] The host of the URI
  #
  # source://http//lib/http/uri.rb#48
  def host; end

  # Sets the host component for the URI
  #
  # @api public
  # @example
  #   uri = HTTP::URI.parse("http://example.com")
  #   uri.host = "other.com"
  # @param new_host [String, #to_str] The new host component
  # @return [void]
  #
  # source://http//lib/http/uri.rb#188
  def host=(new_host); end

  # Checks whether the URI scheme is HTTP
  #
  # @api public
  # @example
  #   HTTP::URI.parse("http://example.com").http?
  # @return [True] if URI is HTTP
  # @return [False] otherwise
  #
  # source://http//lib/http/uri.rb#300
  def http?; end

  # Checks whether the URI scheme is HTTPS
  #
  # @api public
  # @example
  #   HTTP::URI.parse("https://example.com").https?
  # @return [True] if URI is HTTPS
  # @return [False] otherwise
  #
  # source://http//lib/http/uri.rb#312
  def https?; end

  # Returns human-readable representation of URI
  #
  # @api public
  # @example
  #   HTTP::URI.parse("http://example.com").inspect
  # @return [String] human-readable representation of URI
  #
  # source://http//lib/http/uri.rb#355
  def inspect; end

  # Resolves another URI against this one per RFC 3986
  #
  # @api public
  # @example
  #   HTTP::URI.parse("http://example.com/foo/").join("bar")
  # @param other [String, URI] the URI to resolve
  # @return [HTTP::URI] resolved URI
  #
  # source://http//lib/http/uri.rb#263
  def join(other); end

  # Returns a normalized copy of the URI
  #
  # Lowercases scheme and host, strips default port. Used by {#==}
  # to compare URIs for equivalence.
  #
  # @api public
  # @example
  #   HTTP::URI.parse("HTTP://EXAMPLE.COM:80").normalize
  # @return [HTTP::URI] normalized URI
  #
  # source://http//lib/http/uri.rb#279
  def normalize; end

  # Normalized host
  #
  # @api public
  # @example
  #   uri.normalized_host # => "example.com"
  # @return [String, nil] The normalized host of the URI
  #
  # source://http//lib/http/uri.rb#57
  def normalized_host; end

  # Returns a new URI with the specified components removed
  #
  # @api public
  # @example
  #   HTTP::URI.parse("http://example.com#frag").omit(:fragment)
  # @param components [Symbol] URI components to remove
  # @return [HTTP::URI] new URI without the specified components
  #
  # source://http//lib/http/uri.rb#247
  def omit(*components); end

  # The origin (scheme + host + port) per RFC 6454
  #
  # @api public
  # @example
  #   HTTP::URI.parse("http://example.com").origin # => "http://example.com"
  # @return [String] origin of the URI
  #
  # source://http//lib/http/uri.rb#223
  def origin; end

  # Password component for authentication
  #
  # @api public
  # @example
  #   uri.password # => "secret"
  # @return [String, nil] The password component
  #
  # source://http//lib/http/uri.rb#39
  def password; end

  # URI path component
  #
  # @api public
  # @example
  #   uri.path # => "/foo"
  # @return [String] The path component
  #
  # source://http//lib/http/uri.rb#66
  def path; end

  # URI path component
  #
  # @api public
  # @example
  #   uri.path # => "/foo"
  # @return [String] The path component
  #
  # source://http//lib/http/uri.rb#66
  def path=(_arg0); end

  # Port number, either as specified or the default
  #
  # @api public
  # @example
  #   HTTP::URI.parse("http://example.com").port
  # @return [Integer, nil] port number
  #
  # source://http//lib/http/uri.rb#201
  def port; end

  # URI query string
  #
  # @api public
  # @example
  #   uri.query # => "q=1"
  # @return [String, nil] The query component
  #
  # source://http//lib/http/uri.rb#75
  def query; end

  # URI query string
  #
  # @api public
  # @example
  #   uri.query # => "q=1"
  # @return [String, nil] The query component
  #
  # source://http//lib/http/uri.rb#75
  def query=(_arg0); end

  # The path and query for use in an HTTP request line
  #
  # @api public
  # @example
  #   HTTP::URI.parse("http://example.com/path?q=1").request_uri # => "/path?q=1"
  # @return [String] request URI string
  #
  # source://http//lib/http/uri.rb#235
  def request_uri; end

  # URI scheme (e.g. "http", "https")
  #
  # @api public
  # @example
  #   uri.scheme # => "http"
  # @return [String, nil] The URI scheme
  #
  # source://http//lib/http/uri.rb#21
  def scheme; end

  # Convert an HTTP::URI to a String
  #
  # @api public
  # @example
  #   HTTP::URI.parse("http://example.com").to_s
  # @return [String] URI serialized as a String
  #
  # source://http//lib/http/uri.rb#337
  def to_s; end

  # Convert an HTTP::URI to a String
  #
  # @api public
  # @example
  #   HTTP::URI.parse("http://example.com").to_s
  # @return [String] URI serialized as a String
  #
  # source://http//lib/http/uri.rb#346
  def to_str; end

  # User component for authentication
  #
  # @api public
  # @example
  #   uri.user # => "admin"
  # @return [String, nil] The user component
  #
  # source://http//lib/http/uri.rb#30
  def user; end

  private

  # Serialize the authority section of a URI (userinfo + host + port)
  #
  # @api private
  # @return [String] authority component
  #
  # source://http//lib/http/uri/parsing.rb#85
  def authority_string; end

  # Normalize a host for comparison and lookup
  #
  # Percent-decodes, strips trailing dot, lowercases, and IDN-encodes
  # non-ASCII hostnames.
  #
  # @api private
  # @param host [String, nil] the host to normalize
  # @return [String, nil] normalized host
  #
  # source://http//lib/http/uri/parsing.rb#126
  def normalize_host(host); end

  # Adds or removes IPv6 brackets from a host
  #
  # @api private
  # @param brackets [Boolean]
  # @param raw_host [String]
  # @return [String] Host with IPv6 address brackets added or removed
  #
  # source://http//lib/http/uri/parsing.rb#103
  def process_ipv6_brackets(raw_host, brackets: T.unsafe(nil)); end

  class << self
    # Encodes key/value pairs as application/x-www-form-urlencoded
    #
    # @api public
    # @example
    #   HTTP::URI.form_encode(foo: "bar")
    # @param form_values [#to_hash, #to_ary] to encode
    # @param sort [TrueClass, FalseClass] should key/value pairs be sorted first?
    # @return [String] encoded value
    #
    # source://http//lib/http/uri/parsing.rb#37
    def form_encode(form_values, sort: T.unsafe(nil)); end

    # Convert a hostname to ASCII via IDNA (requires addressable)
    #
    # @api private
    # @param host [String] hostname to encode
    # @return [String] ASCII-encoded hostname
    #
    # source://http//lib/http/uri/parsing.rb#72
    def idna_to_ascii(host); end

    # Parse the given URI string, returning an HTTP::URI object
    #
    # @api public
    # @example
    #   HTTP::URI.parse("http://example.com/path")
    # @param uri [HTTP::URI, String, #to_str] to parse
    # @raise [InvalidError]
    # @return [HTTP::URI] new URI instance
    #
    # source://http//lib/http/uri/parsing.rb#15
    def parse(uri); end

    # Percent-encode matching characters in a string
    #
    # @api private
    # @param string [String] raw string
    # @return [String] encoded value
    #
    # source://http//lib/http/uri/parsing.rb#49
    def percent_encode(string); end

    # Loads the addressable gem on first use
    #
    # @api private
    # @raise [LoadError] if addressable gem is not installed
    # @return [void]
    #
    # source://http//lib/http/uri/parsing.rb#60
    def require_addressable; end

    private

    # Parse a URI string into component parts
    #
    # Uses stdlib for printable-ASCII URIs (faster), falling back to
    # Addressable for non-ASCII or when stdlib rejects the input.
    #
    # @api private
    # @param uri_string [String] the URI to parse
    # @return [Hash] URI components
    #
    # source://http//lib/http/uri/parsing.rb#143
    def parse_components(uri_string); end

    # Parse a non-ASCII URI using Addressable
    #
    # @api private
    # @param uri_string [String] the URI to parse
    # @return [Hash] URI components
    #
    # source://http//lib/http/uri/parsing.rb#172
    def parse_with_addressable(uri_string); end

    # Parse an ASCII URI using stdlib
    #
    # @api private
    # @param uri_string [String] the URI to parse
    # @return [Hash, nil] URI components, or nil if stdlib rejects the input
    #
    # source://http//lib/http/uri/parsing.rb#154
    def parse_with_stdlib(uri_string); end

    # Process a single dot-segment removal step per RFC 3986 Section 5.2.4
    #
    # @api private
    # @param input [String] remaining path input (mutated)
    # @param output [String] accumulated result (mutated)
    # @return [void]
    #
    # source://http//lib/http/uri/normalizer.rb#72
    def reduce_dot_segment(input, output); end

    # Remove dot segments from a URI path per RFC 3986 Section 5.2.4
    #
    # @api private
    # @param path [String] URI path to normalize
    # @return [String] path with dot segments removed
    #
    # source://http//lib/http/uri/normalizer.rb#53
    def remove_dot_segments(path); end
  end
end

# Default ports for supported URI schemes
#
# @private
#
# source://http//lib/http/uri.rb#100
HTTP::URI::DEFAULT_PORTS = T.let(T.unsafe(nil), Hash)

# Standalone dot segments that terminate the algorithm
#
# @private
#
# source://http//lib/http/uri/normalizer.rb#29
HTTP::URI::DOT_SEGMENTS = T.let(T.unsafe(nil), Array)

# Matches "/.." followed by "/" or end-of-string
#
# @private
#
# source://http//lib/http/uri/normalizer.rb#37
HTTP::URI::DOUBLE_DOT_SEGMENT = T.let(T.unsafe(nil), Regexp)

# Matches the first path segment, with or without a leading "/"
#
# @private
#
# source://http//lib/http/uri/normalizer.rb#45
HTTP::URI::FIRST_SEGMENT = T.let(T.unsafe(nil), Regexp)

# HTTPS scheme string
#
# @private
#
# source://http//lib/http/uri.rb#92
HTTP::URI::HTTPS_SCHEME = T.let(T.unsafe(nil), String)

# HTTP scheme string
#
# @private
#
# source://http//lib/http/uri.rb#88
HTTP::URI::HTTP_SCHEME = T.let(T.unsafe(nil), String)

# The URI given was not valid
#
# source://http//lib/http/uri.rb#12
class HTTP::URI::InvalidError < ::HTTP::RequestError; end

# Matches the last segment in a path (everything after the final "/")
#
# @private
#
# source://http//lib/http/uri/normalizer.rb#41
HTTP::URI::LAST_SEGMENT = T.let(T.unsafe(nil), Regexp)

# Pattern for characters that stdlib's URI.parse silently modifies
#
# @private
#
# source://http//lib/http/uri.rb#109
HTTP::URI::NEEDS_ADDRESSABLE = T.let(T.unsafe(nil), Regexp)

# Default URI normalizer
#
# @private
#
# source://http//lib/http/uri/normalizer.rb#8
HTTP::URI::NORMALIZER = T.let(T.unsafe(nil), Proc)

# Pattern matching characters requiring percent-encoding
#
# @private
#
# source://http//lib/http/uri.rb#96
HTTP::URI::PERCENT_ENCODE = T.let(T.unsafe(nil), Regexp)

# Matches "/." followed by "/" or end-of-string
#
# @private
#
# source://http//lib/http/uri/normalizer.rb#33
HTTP::URI::SINGLE_DOT_SEGMENT = T.let(T.unsafe(nil), Regexp)

# Requested MimeType adapter not found.
#
# source://http//lib/http/errors.rb#57
class HTTP::UnsupportedMimeTypeError < ::HTTP::Error; end

# Current library version
#
# source://http//lib/http/version.rb#5
HTTP::VERSION = T.let(T.unsafe(nil), String)
