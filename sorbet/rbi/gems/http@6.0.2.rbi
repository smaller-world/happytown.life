  # source://http//lib/http/response.rb#44
  def body; end

  # Charset of response (if any)
  #
  # @api public
  # @example
  #   response.charset # => "utf-8"
  # @return [String, nil]
  #
  # source://http//lib/http/response.rb#256
  def charset(*_arg0, **_arg1, &_arg2); end

  # Check if the response uses chunked transfer encoding
  #
  # @api public
  # @example
  #   response.chunked? # => true
  # @return [Boolean]
  #
  # source://http//lib/http/response.rb#276
  def chunked?; end

  # Return the numeric status code
  #
  # @api public
  # @example
  #   response.code # => 200
  # @return [Integer]
  #
  # source://http//lib/http/response.rb#113
  def code(*_arg0, **_arg1, &_arg2); end

  # Return the underlying connection object
  #
  # @api public
  # @example
  #   response.connection
  # @return [HTTP::Connection]
  #
  # source://http//lib/http/response.rb#139
  def connection(*_arg0, **_arg1, &_arg2); end

  # Value of the Content-Length header
  #
  # @api public
  # @example
  #   response.content_length # => 438
  # @return [nil] if Content-Length was not given, or it's value was invalid
