# Streams HTTP requests to a socket
#
# source://http//lib/http/request/writer.rb#8
class HTTP::Request::Writer
  # Initialize a new request writer
  #
  # @api public
  # @example
  #   Writer.new(socket, body, headers, "GET / HTTP/1.1")
  # @return [HTTP::Request::Writer]
  #
  # source://http//lib/http/request/writer.rb#25
  def initialize(socket, body, headers, headline); end

  # Adds content length or transfer encoding headers
  #
  # @api public
  # @example
  #   writer.add_body_type_headers
  # @return [void]
  #
  # source://http//lib/http/request/writer.rb#77
  def add_body_type_headers; end

  # Adds headers to the request header array
  #
  # @api public
  # @example
  #   writer.add_headers
  # @return [void]
  #
  # source://http//lib/http/request/writer.rb#39
  def add_headers; end

  # Returns true if using chunked transfer encoding
  #
  # @api public
  # @example
  #   writer.chunked?
  # @return [Boolean]
  #
  # source://http//lib/http/request/writer.rb#162
  def chunked?; end

  # Send headers needed to connect through proxy
  #
  # @api public
  # @example
  #   writer.connect_through_proxy
  # @return [void]
  #
  # source://http//lib/http/request/writer.rb#65
  def connect_through_proxy; end

  # Yields chunks of request data for the socket
  #
  # It's important to send the request in a single write call when possible
  # in order to play nicely with Nagle's algorithm. Making two writes in a
  # row triggers a pathological case where Nagle is expecting a third write
  # that never happens.
  #
  # @api public
  # @example
  #   writer.each_chunk { |chunk| socket.write(chunk) }
  # @return [void]
  # @yield [data]
  #
  # source://http//lib/http/request/writer.rb#126
  def each_chunk; end

  # Returns chunk encoded per Transfer-Encoding header
  #
  # @api public
  # @example
  #   writer.encode_chunk("hello")
  # @return [String]
  #
  # source://http//lib/http/request/writer.rb#147
  def encode_chunk(chunk); end

  # Joins headers into an HTTP request header string
  #
  # @api public
  # @example
  #   writer.join_headers
  # @return [String]
  #
  # source://http//lib/http/request/writer.rb#94
  def join_headers; end

  # Writes HTTP request data into the socket
  #
  # @api public
  # @example
  #   writer.send_request
  # @return [void]
  #
  # source://http//lib/http/request/writer.rb#107
  def send_request; end

  # Stream the request to a socket
  #
  # @api public
  # @example
  #   writer.stream
  # @return [void]
  #
  # source://http//lib/http/request/writer.rb#52
  def stream; end

  private

  # Write data to the underlying socket
  #
  # @api private
  # @raise [SocketWriteError] when unable to write to socket
  # @return [void]
  #
  # source://http//lib/http/request/writer.rb#172
  def write(data); end
end

