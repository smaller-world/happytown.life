  # source://http//lib/http/response.rb#184
  def deconstruct_keys(keys); end

  # Flushes body and returns self-reference
  #
  # @api public
  # @example
  #   response.flush # => #<HTTP::Response ...>
  # @return [Response]
  #
  # source://http//lib/http/response.rb#203
  def flush; end

  # The HTTP headers collection
  #
  # @api public
  # @example
  #   response.headers
  # @return [HTTP::Headers] the response headers
  #
  # source://http//lib/http/response.rb#62
  def headers; end

  # Inspect a response
  #
  # @api public
  # @example
  #   response.inspect # => "#<HTTP::Response/1.1 200 OK text/html>"
  # @return [String]
  #
  # source://http//lib/http/response.rb#306
