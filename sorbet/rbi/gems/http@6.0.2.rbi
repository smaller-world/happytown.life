  # source://http//lib/http/form_data/file.rb#86
  def filename_for(io); end

  # Wraps path_or_io into an IO object
  #
  # @api private
  # @param path_or_io [String, Pathname, IO]
  # @return [IO]
  #
  # source://http//lib/http/form_data/file.rb#73
  def make_io(path_or_io); end
end

