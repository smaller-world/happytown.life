  def boundary; end

  # Returns form data content size for Content-Length
  #
  # @api public
  # @example
  #   multipart.content_length # => 123
  # @return [Integer]
  #
  # source://http//lib/http/form_data/multipart.rb#75
  def content_length; end

  # Returns MIME type for the Content-Type header
  #
  # @api public
  # @example
  #   multipart.content_type
  #   # => "multipart/form-data; boundary=-----abc123"
  # @return [String]
  #
  # source://http//lib/http/form_data/multipart.rb#64
  def content_type; end

  private

  # Returns the boundary glue between parts
  #
  # @api private
  # @return [String]
