#
# source://http//lib/http/response/status/reasons.rb#6
class HTTP::Response
  extend ::Forwardable

  # Create a new Response instance
  #
  # @api public
  # @example
  #   Response.new(status: 200, version: "1.1", request: req)
  # @param body [String, nil]
  # @param connection [HTTP::Connection, nil]
  # @param encoding [String, nil] Encoding to use when reading body
  # @param headers [Hash]
  # @param proxy_headers [Hash]
  # @param request [HTTP::Request, nil] The request this is in response to
  # @param status [Integer] Status code
  # @param uri [String, nil] (DEPRECATED) used to populate a missing request
  # @param version [String] HTTP version
  # @return [Response]
  #
  # source://http//lib/http/response.rb#89
  def initialize(status:, version:, headers: T.unsafe(nil), proxy_headers: T.unsafe(nil), connection: T.unsafe(nil), encoding: T.unsafe(nil), body: T.unsafe(nil), request: T.unsafe(nil), uri: T.unsafe(nil)); end

  # The response body
  #
  # @api public
  # @example
  #   response.body
