  # source://http//lib/http/request.rb#350
  def validate_method_and_scheme!; end
end

# Represents an HTTP request body with streaming support
#
# source://http//lib/http/request/body.rb#6
class HTTP::Request::Body
  # Initialize a new request body
  #
  # @api public
  # @example
  #   Body.new("hello world")
  # @return [HTTP::Request::Body]
  #
  # source://http//lib/http/request/body.rb#23
  def initialize(source); end

  # Check equality based on source
  #
  # @api public
  # @example
  #   body == other_body
  # @return [Boolean]
  #
  # source://http//lib/http/request/body.rb#109
  def ==(other); end

  # Yields chunks of content to be streamed
  #
  # @api public
  # @example
  #   body.each { |chunk| socket.write(chunk) }
  # @return [self]
  # @yieldparam [String]
  #
  # source://http//lib/http/request/body.rb#89
  def each(&block); end

  # Whether the body is empty
  #
  # @api public
  # @example
  #   body.empty? # => true
  # @return [Boolean]
  #
  # source://http//lib/http/request/body.rb#36
  def empty?; end

  # Whether the body content can be accessed for logging
  #
  # Returns true for String sources (the content can be inspected).
  # Returns false for IO streams and Enumerables (which cannot be
  # read without consuming them), and for nil bodies.
  #
  # The logging feature checks the string encoding separately to
  # decide whether to log the content as text or format it as binary.
  #
  # @api public
  # @example
  #   body.loggable? # => true
  # @return [Boolean]
  #
  # source://http//lib/http/request/body.rb#54
  def loggable?; end

  # Returns size for the "Content-Length" header
  #
  # @api public
  # @example
  #   body.size
  # @return [Integer]
  #
  # source://http//lib/http/request/body.rb#65
  def size; end

  # The source data for this body
  #
  # @api public
  # @example
  #   body.source # => "hello world"
  # @return [String, Enumerable, IO, nil]
  #
  # source://http//lib/http/request/body.rb#14
  def source; end

  private

  # Rewind an IO source if possible
  #
  # @api private
  # @return [void]
  #
  # source://http//lib/http/request/body.rb#118
  def rewind(io); end

  # Validate that source is a supported type
  #
  # @api private
  # @raise [RequestError]
  # @return [void]
  #
  # source://http//lib/http/request/body.rb#143
  def validate_source_type!; end
end

# This class provides a "writable IO" wrapper around a proc object, with
