# HTTP caching feature that stores and reuses responses according to
# RFC 7234. Only GET and HEAD responses are cached. Supports
# `Cache-Control`, `Expires`, `ETag`, and `Last-Modified` for freshness
# checks and conditional revalidation.
#
# @example Basic usage with in-memory cache
#   HTTP.use(:caching).get("https://example.com/")
# @example With a shared store across requests
#   store = HTTP::Features::Caching::InMemoryStore.new
#   client = HTTP.use(caching: { store: store })
#   client.get("https://example.com/")
#
# source://http//lib/http/features/caching/entry.rb#7
class HTTP::Features::Caching < ::HTTP::Feature
  # Initializes the Caching feature
  #
  # @api public
  # @example
  #   Caching.new(store: InMemoryStore.new)
  # @param store [#lookup, #store] cache store instance
  # @return [Caching]
  #
  # source://http//lib/http/features/caching.rb#44
  def initialize(store: T.unsafe(nil)); end

  # Wraps the HTTP exchange with caching logic
  #
  # Checks the cache before making a request. Returns a cached response
  # if fresh; otherwise adds conditional headers and revalidates. Stores
  # cacheable responses for future use.
  #
  # @api public
  # @example
  #   feature.around_request(request) { |req| perform_exchange(req) }
  # @param request [HTTP::Request]
  # @return [HTTP::Response]
  # @yield Executes the HTTP exchange
  # @yieldreturn [HTTP::Response]
  #
  # source://http//lib/http/features/caching.rb#62
  def around_request(request); end

  # The cache store instance
  #
  # @api public
  # @example
  #   feature.store
  # @return [#lookup, #store] the cache store
  #
  # source://http//lib/http/features/caching.rb#34
  def store; end

  # Stores cacheable responses in the cache
  #
  # @api public
  # @example
  #   feature.wrap_response(response)
  # @param response [HTTP::Response]
  # @return [HTTP::Response]
  #
  # source://http//lib/http/features/caching.rb#86
  def wrap_response(response); end

  private

  # Add conditional headers from a cached entry to the request
  #
  # @api private
  # @return [HTTP::Request]
  #
  # source://http//lib/http/features/caching.rb#177
  def add_conditional_headers(request, entry); end

  # Build a response from a cached entry
  #
  # @api private
  # @return [HTTP::Response]
  #
  # source://http//lib/http/features/caching.rb#195
  def build_cached_response(entry, request); end

  # Build a cache entry from a response
  #
  # @api private
  # @return [Entry]
  #
  # source://http//lib/http/features/caching.rb#124
  def build_entry(response, body_string); end

  # Check whether this request method is cacheable
  #
  # @api private
  # @return [Boolean]
  #
  # source://http//lib/http/features/caching.rb#139
  def cacheable_request?(request); end

  # Check whether this response is cacheable
  #
  # @api private
  # @return [Boolean]
  #
  # source://http//lib/http/features/caching.rb#146
  def cacheable_response?(response); end

  # Whether the response carries enough information to determine freshness
  #
  # @api private
  # @return [Boolean]
  #
  # source://http//lib/http/features/caching.rb#159
  def freshness_info?(response, directives); end

  # Current time (extracted for testability)
  #
  # @api private
  # @return [Time]
  #
  # source://http//lib/http/features/caching.rb#209
  def now; end

  # Parse Cache-Control header into a list of directives
  #
  # @api private
  # @return [Array<String>]
  #
  # source://http//lib/http/features/caching.rb#170
  def parse_cache_control(headers); end

  # Revalidate a cached entry with a 304 response
  #
  # @api private
  # @return [HTTP::Response]
  #
  # source://http//lib/http/features/caching.rb#98
