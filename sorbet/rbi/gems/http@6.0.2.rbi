  # source://http//lib/http/form_data/multipart.rb#99
  def parts(data); end

  # Returns the closing boundary tail
  #
  # @api private
  # @return [String]
  #
  # source://http//lib/http/form_data/multipart.rb#91
  def tail; end

  class << self
    # Generates a boundary string for multipart form data
    #
    # @api public
    # @example
    #   Multipart.generate_boundary # => "-----abc123..."
    # @return [String]
    #
    # source://http//lib/http/form_data/multipart.rb#52
    def generate_boundary; end
  end
end

