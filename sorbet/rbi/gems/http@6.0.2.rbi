  # source://http//lib/http/features/caching/entry.rb#163
  def expires_at; end

  # max-age value from Cache-Control, if present
  #
  # @api private
  # @return [Integer, nil]
  #
  # source://http//lib/http/features/caching/entry.rb#153
  def max_age; end

  # Whether the Cache-Control includes no-cache
  #
  # @api private
  # @return [Boolean]
  #
  # source://http//lib/http/features/caching/entry.rb#172
  def no_cache?; end
end

# Simple in-memory cache store backed by a Hash
#
# Cache keys are derived from the request method and URI.
#
# @example
#   store = InMemoryStore.new
#   store.store(request, entry)
#   store.lookup(request) # => entry
#
# source://http//lib/http/features/caching/in_memory_store.rb#15
class HTTP::Features::Caching::InMemoryStore
  # Create a new empty in-memory store
  #
  # @api public
  # @example
  #   store = InMemoryStore.new
  # @return [InMemoryStore]
  #
  # source://http//lib/http/features/caching/in_memory_store.rb#23
  def initialize; end

  # Look up a cached entry for a request
  #
  # @api public
  # @example
  #   store.lookup(request) # => Entry or nil
  # @param request [HTTP::Request]
  # @return [Entry, nil]
  #
  # source://http//lib/http/features/caching/in_memory_store.rb#35
  def lookup(request); end

  # Store a cache entry for a request
  #
  # @api public
  # @example
  #   store.store(request, entry)
  # @param entry [Entry]
  # @param request [HTTP::Request]
  # @return [Entry]
  #
  # source://http//lib/http/features/caching/in_memory_store.rb#48
  def store(request, entry); end

  private

  # Compute the cache key for a request
  #
  # @api private
  # @return [String]
  #
  # source://http//lib/http/features/caching/in_memory_store.rb#57
  def cache_key(request); end
end

# Implements HTTP Digest Authentication (RFC 2617 / RFC 7616)
#
# When a server responds with 401 and a Digest challenge, this feature
# automatically computes the digest response and retries the request
# with the correct Authorization header.
#
# source://http//lib/http/features/digest_auth.rb#13
class HTTP::Features::DigestAuth < ::HTTP::Feature
  # Initialize the DigestAuth feature
  #
  # @api public
  # @example
  #   DigestAuth.new(user: "admin", pass: "secret")
  # @param pass [String] password for authentication
  # @param user [String] username for authentication
  # @return [DigestAuth]
  #
  # source://http//lib/http/features/digest_auth.rb#35
  def initialize(user:, pass:); end

  # Wraps the HTTP exchange to handle digest authentication challenges
  #
  # On a 401 with a Digest WWW-Authenticate header, flushes the error
  # response, computes digest credentials, and retries the request.
  #
  # @api public
  # @example
  #   feature.around_request(request) { |req| perform(req) }
  # @param request [HTTP::Request]
  # @return [HTTP::Response]
  # @yield [HTTP::Request] the request to perform
  # @yieldreturn [HTTP::Response]
  #
  # source://http//lib/http/features/digest_auth.rb#53
  def around_request(request); end

  private

  # Build an authorized copy of the request using the digest challenge
  #
  # @api private
  # @param request [HTTP::Request] the original request
  # @param response [HTTP::Response] the 401 response with challenge
  # @return [HTTP::Request] a new request with Authorization header
  #
  # source://http//lib/http/features/digest_auth.rb#79
  def authorize(request, response); end

  # Build the Authorization header value
  #
  # @api private
  # @param challenge [Hash{String => String}] parsed challenge params
  # @param request [HTTP::Request] the request being authorized
  # @return [String] the Digest authorization header value
  #
  # source://http//lib/http/features/digest_auth.rb#116
  def build_auth(request, challenge); end

  # Build the Digest Authorization header string
  #
  # @api private
  # @return [String] formatted header value
  #
  # source://http//lib/http/features/digest_auth.rb#213
  def build_header(username:, realm:, nonce:, uri:, qop:, nonce_count:, cnonce:, response:, opaque:, algorithm:); end

  # Compute digest and build the Authorization header string
  #
  # @api private
  # @return [String] formatted authorization header
  #
  # source://http//lib/http/features/digest_auth.rb#135
  def compute_auth_header(algorithm:, qop:, nonce:, cnonce:, nonce_count:, uri:, ha1:, ha2:, challenge:); end

  # Compute HA1 per RFC 2617
  #
  # @api private
  # @return [String] hex digest
  #
  # source://http//lib/http/features/digest_auth.rb#162
  def compute_ha1(algorithm, realm, nonce, cnonce); end

  # Compute HA2 per RFC 2617
  #
  # @api private
  # @return [String] hex digest
  #
  # source://http//lib/http/features/digest_auth.rb#176
  def compute_ha2(algorithm, method, uri); end

  # Compute the final digest response value
  #
  # @api private
  # @param algorithm [String] algorithm name
  # @param cnonce [String] client nonce
  # @param ha1 [String] HA1 hex digest
  # @param ha2 [String] HA2 hex digest
  # @param nonce [String] server nonce
  # @param nonce_count [String] request counter
  # @param qop [String, nil] quality of protection
  # @return [String] hex digest
  #
  # source://http//lib/http/features/digest_auth.rb#191
  def compute_response(algorithm, ha1, ha2, nonce:, nonce_count:, cnonce:, qop:); end

  # Check if the response contains a digest authentication challenge
  #
  # @api private
  # @param response [HTTP::Response]
  # @return [Boolean]
  #
  # source://http//lib/http/features/digest_auth.rb#68
  def digest_challenge?(response); end

  # Compute a hex digest using the specified algorithm
  #
  # @api private
  # @param algorithm [String] algorithm name
  # @param data [String] data to digest
  # @return [String] hex digest
  #
  # source://http//lib/http/features/digest_auth.rb#205
  def hex_digest(algorithm, data); end

  # Parse the WWW-Authenticate header into a parameter hash
  #
  # @api private
  # @param header [String] the WWW-Authenticate header value
  # @return [Hash{String => String}] parsed challenge parameters
  #
  # source://http//lib/http/features/digest_auth.rb#101
  def parse_challenge(header); end

  # Select the best qop value from the challenge
  #
  # @api private
  # @param qop_str [String, nil] comma-separated qop options
  # @return [String, nil] selected qop value
  #
  # source://http//lib/http/features/digest_auth.rb#149
  def select_qop(qop_str); end
end

# Supported hash algorithms
#
# source://http//lib/http/features/digest_auth.rb#15
HTTP::Features::DigestAuth::ALGORITHMS = T.let(T.unsafe(nil), Hash)

# WWW-Authenticate header name
#
# @api private
#
# source://http//lib/http/features/digest_auth.rb#24
HTTP::Features::DigestAuth::WWW_AUTHENTICATE = T.let(T.unsafe(nil), String)

# Instrument requests and responses. Expects an
# ActiveSupport::Notifications-compatible instrumenter. Defaults to use a
# namespace of 'http' which may be overridden with a `:namespace` param.
# Emits a single event like `"request.{namespace}"`, eg `"request.http"`.
# Be sure to specify the instrumenter when enabling the feature:
#
#    HTTP
#      .use(instrumentation: {instrumenter: ActiveSupport::Notifications.instrumenter})
#      .get("https://example.com/")
#
# Emits two events on every request:
#
#  * `start_request.http` before the request is made, so you can log the reqest being started
#  * `request.http` after the response is recieved, and contains `start`
#    and `finish` so the duration of the request can be calculated.
#
# source://http//lib/http/features/instrumentation.rb#21
class HTTP::Features::Instrumentation < ::HTTP::Feature
  # Initializes the Instrumentation feature
  #
  # @api public
  # @example
  #   Instrumentation.new(instrumenter: ActiveSupport::Notifications.instrumenter)
  # @param instrumenter [#instrument] instrumenter instance
  # @param namespace [String] event namespace
  # @return [Instrumentation]
  #
  # source://http//lib/http/features/instrumentation.rb#58
  def initialize(instrumenter: T.unsafe(nil), namespace: T.unsafe(nil)); end

  # Wraps the HTTP exchange with instrumentation
  #
  # Emits a `"start_request.http"` event before the request, then wraps
  # the exchange in a `"request.http"` span that is guaranteed to close
  # on both success and failure (via the instrumenter's ensure block).
  #
  # @api public
  # @example
  #   feature.around_request(request) { perform_io }
  # @param request [HTTP::Request]
  # @return [HTTP::Response]
  # @yield Executes the HTTP exchange
  # @yieldreturn [HTTP::Response]
  #
  # source://http//lib/http/features/instrumentation.rb#79
  def around_request(request); end

  # The event name for errors
  #
  # @api public
  # @example
  #   feature.error_name # => "error.http"
  # @return [String] the event name for errors
  #
  # source://http//lib/http/features/instrumentation.rb#47
  def error_name; end

  # The instrumenter instance
  #
  # @api public
  # @example
  #   feature.instrumenter
  # @return [#instrument] the instrumenter instance
  #
  # source://http//lib/http/features/instrumentation.rb#29
  def instrumenter; end

  # The event name for requests
  #
  # @api public
  # @example
  #   feature.name # => "request.http"
  # @return [String] the event name for requests
  #
  # source://http//lib/http/features/instrumentation.rb#38
  def name; end

  # Instruments a request error
  #
  # @api public
  # @example
  #   feature.on_error(request, error)
  # @param error [Exception]
  # @param request [HTTP::Request]
  # @return [Object]
  #
  # source://http//lib/http/features/instrumentation.rb#99
  def on_error(request, error); end
end

# No-op instrumenter used as default when none is provided
#
# source://http//lib/http/features/instrumentation.rb#106
class HTTP::Features::Instrumentation::NullInstrumenter
  # Finishes an instrumentation event
  #
  # @api public
  # @example
  #   instrumenter.finish("request.http", response: resp)
  # @param _name [String]
  # @param _payload [Hash]
  # @return [nil]
  #
  # source://http//lib/http/features/instrumentation.rb#145
  def finish(_name, _payload); end

  # Instruments an event with a name and payload
  #
  # @api public
  # @example
  #   instrumenter.instrument("request.http", request: req)
  # @param name [String]
  # @param payload [Hash]
  # @return [Object]
  #
  # source://http//lib/http/features/instrumentation.rb#116
  def instrument(name, payload = T.unsafe(nil)); end

  # Starts an instrumentation event
  #
  # @api public
  # @example
  #   instrumenter.start("request.http", request: req)
  # @param _name [String]
  # @param _payload [Hash]
  # @return [nil]
  #
  # source://http//lib/http/features/instrumentation.rb#134
  def start(_name, _payload); end
end

# Log requests and responses. Request verb and uri, and Response status are
# logged at `info`, and the headers and bodies of both are logged at
# `debug`. Be sure to specify the logger when enabling the feature:
#
#    HTTP.use(logging: {logger: Logger.new(STDOUT)}).get("https://example.com/")
#
# Binary bodies (IO/Enumerable request sources and binary-encoded
# responses) are formatted using the +binary_formatter+ option instead
# of being dumped raw. Available formatters:
#
# - +:stats+ (default) — logs <tt>BINARY DATA (N bytes)</tt>
# - +:base64+ — logs <tt>BINARY DATA (N bytes)\n<base64></tt>
# - +Proc+ — calls the proc with the raw binary string
#
# @example Custom binary formatter
#   HTTP.use(logging: {logger: Logger.new(STDOUT), binary_formatter: :base64})
#
# source://http//lib/http/features/logging.rb#23
class HTTP::Features::Logging < ::HTTP::Feature
  # Initializes the Logging feature
  #
  # @api public
  # @example
  #   Logging.new(logger: Logger.new(STDOUT))
  # @example With binary formatter
  #   Logging.new(logger: Logger.new(STDOUT), binary_formatter: :base64)
  # @param binary_formatter [:stats, :base64, #call] how to log binary bodies
  # @param logger [#info, #debug] logger instance
  # @return [Logging]
  #
  # source://http//lib/http/features/logging.rb#60
  def initialize(logger: T.unsafe(nil), binary_formatter: T.unsafe(nil)); end

  # The logger instance
  #
  # @api public
  # @example
  #   feature.logger
  # @return [#info, #debug] the logger instance
  #
  # source://http//lib/http/features/logging.rb#46
  def logger; end

  # Logs and returns the request
  #
  # @api public
  # @example
  #   feature.wrap_request(request)
  # @param request [HTTP::Request]
  # @return [HTTP::Request]
  #
  # source://http//lib/http/features/logging.rb#74
  def wrap_request(request); end

  # Logs and returns the response
  #
  # @api public
  # @example
  #   feature.wrap_response(response)
  # @param response [HTTP::Response]
  # @return [HTTP::Response]
  #
  # source://http//lib/http/features/logging.rb#89
  def wrap_response(response); end

  private

  # Format binary data according to the configured binary_formatter
  #
  # @api private
  # @return [String]
  #
  # source://http//lib/http/features/logging.rb#169
  def format_binary(data); end

  # Log request headers and body (when loggable)
  #
  # @api private
  # @return [void]
  #
  # source://http//lib/http/features/logging.rb#117
  def log_request_details(request); end

  # Log response with body inline (for non-streaming string bodies)
  #
  # @api private
  # @return [HTTP::Response]
  #
  # source://http//lib/http/features/logging.rb#131
  def log_response_body_inline(response); end

  # Wrap a response body with a logging stream
  #
  # @api private
  # @return [HTTP::Response::Body]
  #
  # source://http//lib/http/features/logging.rb#160
  def logged_body(body); end

  # Build options hash for a response with body logging
  #
  # @api private
  # @return [Hash]
  #
  # source://http//lib/http/features/logging.rb#145
  def logged_response_options(response); end

  # Convert headers to a string representation
  #
  # @api private
  # @return [String]
  #
  # source://http//lib/http/features/logging.rb#183
  def stringify_headers(headers); end

  # Validate and return the binary_formatter option
  #
  # @api private
  # @raise [ArgumentError] if the formatter is not a valid option
  # @return [:stats, :base64, #call]
  #
  # source://http//lib/http/features/logging.rb#106
  def validate_binary_formatter!(formatter); end
end

# Stream wrapper that logs each chunk as it flows through readpartial
#
# source://http//lib/http/features/logging.rb#188
class HTTP::Features::Logging::BodyLogger
  # Create a new BodyLogger wrapping a stream
  #
  # @api public
  # @example
  #   BodyLogger.new(stream, logger)
  # @param formatter [#call, nil] optional formatter for each chunk
  # @param logger [#debug] the logger instance
  # @param stream [#readpartial] the stream to wrap
  # @return [BodyLogger]
  #
  # source://http//lib/http/features/logging.rb#208
  def initialize(stream, logger, formatter: T.unsafe(nil)); end

  # The underlying connection
  #
  # @api public
  # @example
  #   body_logger.connection
  # @return [HTTP::Connection] the underlying connection
  #
  # source://http//lib/http/features/logging.rb#196
  def connection; end

  # Read a chunk from the underlying stream and log it
  #
  # @api public
  # @example
  #   body_logger.readpartial # => "chunk"
  # @raise [EOFError] when no more data left
  # @return [String] the chunk read from the stream
  #
  # source://http//lib/http/features/logging.rb#223
  def readpartial(*_arg0); end
end

# No-op logger used as default when none is provided
#
# source://http//lib/http/features/logging.rb#27
class HTTP::Features::Logging::NullLogger
  # source://http//lib/http/features/logging.rb#29
  def debug(*_args); end

  # source://http//lib/http/features/logging.rb#33
  def debug?; end

  # source://http//lib/http/features/logging.rb#29
  def error(*_args); end

  # source://http//lib/http/features/logging.rb#33
  def error?; end

  # source://http//lib/http/features/logging.rb#29
  def fatal(*_args); end

  # source://http//lib/http/features/logging.rb#33
  def fatal?; end

  # source://http//lib/http/features/logging.rb#29
  def info(*_args); end

  # source://http//lib/http/features/logging.rb#33
  def info?; end

  # source://http//lib/http/features/logging.rb#29
  def warn(*_args); end

  # source://http//lib/http/features/logging.rb#33
  def warn?; end
end

# Normalizes request URIs before sending
#
# source://http//lib/http/features/normalize_uri.rb#8
class HTTP::Features::NormalizeUri < ::HTTP::Feature
  # Initializes the NormalizeUri feature
  #
  # @api public
  # @example
  #   NormalizeUri.new(normalizer: HTTP::URI::NORMALIZER)
  # @param normalizer [#call] URI normalizer
  # @return [NormalizeUri]
  #
  # source://http//lib/http/features/normalize_uri.rb#26
  def initialize(normalizer: T.unsafe(nil)); end

  # The URI normalizer proc
  #
  # @api public
  # @example
  #   feature.normalizer
  # @return [#call] the URI normalizer proc
  #
  # source://http//lib/http/features/normalize_uri.rb#16
  def normalizer; end
end

# Raises an error for non-successful HTTP responses
#
# source://http//lib/http/features/raise_error.rb#6
class HTTP::Features::RaiseError < ::HTTP::Feature
  # Initializes the RaiseError feature
  #
  # @api public
  # @example
  #   RaiseError.new(ignore: [404])
  # @param ignore [Array<Integer>] status codes to ignore
  # @return [RaiseError]
  #
  # source://http//lib/http/features/raise_error.rb#15
  def initialize(ignore: T.unsafe(nil)); end

  # Raises an error for non-successful responses
  #
  # @api public
  # @example
  #   feature.wrap_response(response)
  # @param response [HTTP::Response]
  # @raise [StatusError]
  # @return [HTTP::Response]
  #
  # source://http//lib/http/features/raise_error.rb#27
  def wrap_response(response); end
end

# Utility-belt to build form data request bodies.
# Provides support for `application/x-www-form-urlencoded` and
# `multipart/form-data` types.
#
# @example Usage
#
#   form = FormData.create({
#   username:    "ixti",
#   avatar_file: FormData::File.new("/home/ixti/avatar.png")
#   })
#
#   # Assuming socket is an open socket to some HTTP server
#   socket << "POST /some-url HTTP/1.1\r\n"
#   socket << "Host: example.com\r\n"
#   socket << "Content-Type: #{form.content_type}\r\n"
#   socket << "Content-Length: #{form.content_length}\r\n"
#   socket << "\r\n"
#   socket << form.to_s
#
# source://http//lib/http/form_data/readable.rb#4
module HTTP::FormData
  class << self
    # Selects encoder type based on given data
    #
    # @api public
    # @example
    #   FormData.create({ username: "ixti" })
    # @param data [Enumerable, Hash, #to_h]
    # @return [Multipart] if any of values is a {FormData::File}
    # @return [Urlencoded] otherwise
    #
    # source://http//lib/http/form_data.rb#47
    def create(data, encoder: T.unsafe(nil)); end

    # Coerces obj to an Enumerable of key-value pairs
    #
    # @api public
    # @example
    #   FormData.ensure_data([[:foo, :bar]]) # => [[:foo, :bar]]
    # @raise [Error] `obj` can't be coerced
    # @return [Enumerable]
    #
    # source://http//lib/http/form_data.rb#80
    def ensure_data(obj); end

    # Coerces obj to Hash
    #
    # @api public
    # @example
    #   FormData.ensure_hash({ foo: :bar }) # => { foo: :bar }
    # @raise [Error] `obj` can't be coerced
    # @return [Hash]
    #
    # source://http//lib/http/form_data.rb#65
    def ensure_hash(obj); end

    private

    # Checks if data contains multipart data
    #
    # @api private
    # @param data [Enumerable]
    # @return [Boolean]
    #
    # source://http//lib/http/form_data.rb#95
    def multipart?(data); end
  end
end

# CRLF
#
# source://http//lib/http/form_data.rb#32
HTTP::FormData::CRLF = T.let(T.unsafe(nil), String)

# Provides IO interface across multiple IO objects.
#
# source://http//lib/http/form_data/composite_io.rb#8
class HTTP::FormData::CompositeIO
  # Creates a new CompositeIO from an array of IOs
  #
  # @api public
  # @example
  #   CompositeIO.new([StringIO.new("hello"), StringIO.new(" world")])
  # @param ios [Array<IO>] Array of IO objects
  # @return [CompositeIO] a new instance of CompositeIO
  #
  # source://http//lib/http/form_data/composite_io.rb#16
  def initialize(ios); end

  # Reads and returns content across multiple IO objects
  #
  # @api public
  # @example
  #   composite_io.read     # => "hello world"
  #   composite_io.read(5)  # => "hello"
  # @param length [Integer] Number of bytes to retrieve
  # @param outbuf [String] String to be replaced with retrieved data
  # @return [String, nil]
  #
  # source://http//lib/http/form_data/composite_io.rb#40
  def read(length = T.unsafe(nil), outbuf = T.unsafe(nil)); end

  # Rewinds all IO objects and resets cursor
  #
  # @api public
  # @example
  #   composite_io.rewind
  # @return [void]
  #
  # source://http//lib/http/form_data/composite_io.rb#67
  def rewind; end

  # Returns sum of all IO sizes
  #
  # @api public
  # @example
  #   composite_io.size # => 11
  # @return [Integer]
  #
  # source://http//lib/http/form_data/composite_io.rb#56
  def size; end

  private

  # Yields chunks with total length up to `length`
  #
  # @api private
  # @return [void]
  #
  # source://http//lib/http/form_data/composite_io.rb#78
  def read_chunks(length); end

  # Reads chunk from current IO with length up to `max_length`
  #
  # @api private
  # @return [String, nil]
  #
  # source://http//lib/http/form_data/composite_io.rb#95
  def readpartial(max_length); end
end

# Generic FormData error.
#
# source://http//lib/http/form_data.rb#35
class HTTP::FormData::Error < ::StandardError; end

# Represents file form param.
#
# @example Usage with IO
#
#   File.open "/home/ixti/avatar.png" do |io|
#   FormData::File.new io
#   end
# @example Usage with StringIO
#
#   io = StringIO.new "foo bar baz"
#   FormData::File.new io, filename: "foobar.txt"
# @example Usage with pathname
#
#   FormData::File.new "/home/ixti/avatar.png"
#
# source://http//lib/http/form_data/file.rb#21
class HTTP::FormData::File < ::HTTP::FormData::Part
  # Creates a new File from a path or IO object
  #
  # @api public
  # @example
  #   File.new("/path/to/file.txt")
  # @option opts
  # @option opts
  # @param opts [#to_h]
  # @param path_or_io [String, Pathname, IO] Filename or IO instance
  # @return [File] a new instance of File
  # @see DEFAULT_MIME
  #
  # source://http//lib/http/form_data/file.rb#39
  def initialize(path_or_io, opts = T.unsafe(nil)); end

  # Closes the underlying IO if it was opened by this instance
  #
  # When the File was created from a String path or Pathname, the
  # underlying file handle is closed. When created from an existing
  # IO object, this is a no-op (the caller is responsible for
  # closing it).
  #
  # @api public
  # @example
  #   file = FormData::File.new("/path/to/file.txt")
  #   file.to_s
  #   file.close
  # @return [void]
