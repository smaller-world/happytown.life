  # @api public
  # @example
  #   readable.size # => 42
  # @return [Integer]
  #
  # source://http//lib/http/form_data/readable.rb#42
  def size; end

  # Returns IO content as a String
  #
  # @api public
  # @example
  #   readable.to_s # => "content"
  # @return [String]
  #
  # source://http//lib/http/form_data/readable.rb#14
  def to_s; end
end

# `application/x-www-form-urlencoded` form data.
#
# source://http//lib/http/form_data/urlencoded.rb#11
class HTTP::FormData::Urlencoded
  include ::HTTP::FormData::Readable

  # Creates a new Urlencoded form data instance
  #
  # @api public
  # @example
  #   Urlencoded.new({ "foo" => "bar" })
  # @param data [Enumerable, Hash, #to_h] form data key-value pairs
  # @param encoder [#call] custom encoder implementation
  # @return [Urlencoded] a new instance of Urlencoded
  #
  # source://http//lib/http/form_data/urlencoded.rb#148
  def initialize(data, encoder: T.unsafe(nil)); end

  # Returns form data content size for Content-Length
  #
  # @api public
  # @example
  #   urlencoded.content_length # => 17
  # @return [Integer]
  #
  # source://http//lib/http/form_data/urlencoded.rb#172
  def content_length; end

  # Returns MIME type for the Content-Type header
  #
  # @api public
  # @example
  #   urlencoded.content_type
  #   # => "application/x-www-form-urlencoded"
  # @return [String]
  #
  # source://http//lib/http/form_data/urlencoded.rb#161
  def content_type; end

  class << self
    # Returns form data encoder implementation
    #
    # @api public
    # @example
    #   Urlencoded.encoder # => #<Method: DefaultEncoder.encode>
    # @return [#call]
    # @see .encoder=
    #
    # source://http//lib/http/form_data/urlencoded.rb#65
    def encoder; end

    # Sets custom form data encoder implementation
    #
    # @api public
    # @example
    #
    #   module CustomFormDataEncoder
    #   UNESCAPED_CHARS = /[^a-z0-9\-\.\_\~]/i
    #
    #   def self.escape(s)
    #   ::URI::DEFAULT_PARSER.escape(s.to_s, UNESCAPED_CHARS)
    #   end
    #
    #   def self.call(data)
    #   parts = []
    #
    #   data.each do |k, v|
    #   k = escape(k)
    #
    #   if v.nil?
    #   parts << k
    #   elsif v.respond_to?(:to_ary)
    #   v.to_ary.each { |vv| parts << "#{k}=#{escape vv}" }
    #   else
    #   parts << "#{k}=#{escape v}"
    #   end
    #   end
    #
    #   parts.join("&")
    #   end
    #   end
    #
    #   HTTP::FormData::Urlencoded.encoder = CustomFormDataEncoder
    # @param implementation [#call]
    # @raise [ArgumentError] if implementation does not respond to `#call`
    # @return [void]
    #
    # source://http//lib/http/form_data/urlencoded.rb#51
    def encoder=(implementation); end
  end
end

# Gem version.
#
# source://http//lib/http/form_data/version.rb#6
HTTP::FormData::VERSION = T.let(T.unsafe(nil), String)

# Header value is of unexpected format (similar to Net::HTTPHeaderSyntaxError)
#
# source://http//lib/http/errors.rb#66
class HTTP::HeaderError < ::HTTP::Error; end

# HTTP Headers container.
#
# source://http//lib/http/headers/normalizer.rb#4
class HTTP::Headers
  include ::Enumerable
  extend ::Forwardable

  # Creates a new empty headers container
  #
  # @api public
  # @example
  #   headers = HTTP::Headers.new
  # @return [Headers]
  #
  # source://http//lib/http/headers.rb#66
  def initialize; end

  # Compares headers to another Headers or Array of pairs
  #
  # @api public
  # @example
  #   headers == other_headers
  # @return [Boolean]
  #
  # source://http//lib/http/headers.rb#234
  def ==(other); end

  # Smart version of {#get}
  #
  # @api public
  # @example
  #   headers["Content-Type"]
  # @return [nil] if header was not set
  # @return [String] if header has exactly one value
  # @return [Array<String>] if header has more than one value
  #
  # source://http//lib/http/headers.rb#158
  def [](name); end

  # Sets header, replacing any existing values
  #
  # @api public
  # @example
  #   headers.set("Content-Type", "text/plain")
  # @return [void]
  #
  # source://http//lib/http/headers.rb#95
  def []=(name, value); end

  # Appends header value(s) to the given name
  #
  # @api public
  # @example
  #   headers.add("Accept", "text/html")
  # @param name [String, Symbol] header name. When specified as a string, the
  #   name is sent as-is. When specified as a symbol, the name is converted
  #   to a string of capitalized words separated by a dash. Word boundaries
  #   are determined by an underscore (`_`) or a dash (`-`).
  #   Ex: `:content_type` is sent as `"Content-Type"`, and `"auth_key"` (string)
  #   is sent as `"auth_key"`.
  # @param value [Array<#to_s>, #to_s] header value(s) to be appended
  # @return [void]
  #
  # source://http//lib/http/headers.rb#124
  def add(name, value); end

  # Pattern matching interface
  #
  # @api public
  # @example
  #   headers.deconstruct_keys(%i[content_type])
  # @param keys [Array<Symbol>, nil] keys to extract, or nil for all
  # @return [Hash{Symbol => Object}]
  #
  # source://http//lib/http/headers.rb#202
  def deconstruct_keys(keys); end

  # Removes header with the given name
  #
  # @api public
  # @example
  #   headers.delete("Content-Type")
  # @param name [#to_s] header name
  # @return [void]
  #
  # source://http//lib/http/headers.rb#105
  def delete(name); end

  # Calls the given block once for each key/value pair
  #
  # @api public
  # @example
  #   headers.each { |name, value| puts "#{name}: #{value}" }
  # @return [Enumerator] if no block given
  # @return [Headers] self-reference
  #
  # source://http//lib/http/headers.rb#248
  def each; end

  # Returns true if self has no key/value pairs
  #
  # @api public
  # @example
  #   headers.empty?
  # @return [Boolean]
  #
  # source://http//lib/http/headers.rb#263
  def empty?(*_arg0, **_arg1, &_arg2); end

  # Returns list of header values if any
  #
  # @api public
  # @example
  #   headers.get("Content-Type")
  # @return [Array<String>]
  #
  # source://http//lib/http/headers.rb#144
  def get(name); end

  # Computes a hash-code for this headers container
  #
  # @api public
  # @example
  #   headers.hash
  # @return [Fixnum]
  # @see http://www.ruby-doc.org/core/Object.html#method-i-hash
  #
  # source://http//lib/http/headers.rb#274
  def hash(*_arg0, **_arg1, &_arg2); end

  # Tells whether header with given name is set
  #
  # @api public
  # @example
  #   headers.include?("Content-Type")
  # @return [Boolean]
  #
  # source://http//lib/http/headers.rb#174
  def include?(name); end

  # Returns human-readable representation of self instance
  #
  # @api public
  # @example
  #   headers.inspect
  # @return [String]
  #
  # source://http//lib/http/headers.rb#214
  def inspect; end

  # Returns list of header names
  #
  # @api public
  # @example
  #   headers.keys
  # @return [Array<String>]
  #
  # source://http//lib/http/headers.rb#223
  def keys; end

  # Returns new instance with other headers merged in
  #
  # @api public
  # @example
  #   new_headers = headers.merge("Accept" => "text/html")
  # @return [Headers]
  # @see #merge!
  #
  # source://http//lib/http/headers.rb#306
  def merge(other); end

  # Merges other headers into self
  #
  # @api public
  # @example
  #   headers.merge!("Accept" => "text/html")
  # @return [void]
  # @see #merge
  #
  # source://http//lib/http/headers.rb#292
  def merge!(other); end

  # Sets header, replacing any existing values
  #
  # @api public
  # @example
  #   headers.set("Content-Type", "text/plain")
  # @param name [String, Symbol] header name. When specified as a string, the
  #   name is sent as-is. When specified as a symbol, the name is converted
  #   to a string of capitalized words separated by a dash. Word boundaries
  #   are determined by an underscore (`_`) or a dash (`-`).
  #   Ex: `:content_type` is sent as `"Content-Type"`, and `"auth_key"` (string)
  #   is sent as `"auth_key"`.
  # @param value [Array<#to_s>, #to_s] header value(s) to be appended
  # @return [void]
  #
  # source://http//lib/http/headers.rb#82
  def set(name, value); end

  # Returns Rack-compatible headers Hash
  #
  # @api public
  # @example
  #   headers.to_h
  # @return [Hash]
  #
  # source://http//lib/http/headers.rb#186
  def to_h; end

  # Returns Rack-compatible headers Hash
  #
  # @api public
  # @example
  #   headers.to_h
  # @return [Hash]
  #
  # source://http//lib/http/headers.rb#192
  def to_hash; end

  private

  # Properly clones internal key/value storage
  #
  # @api private
  # @return [void]
  #
  # source://http//lib/http/headers.rb#280
  def initialize_copy(_orig); end

  # Transforms name to canonical HTTP header capitalization
  #
  # @api private
  # @return [String]
  #
  # source://http//lib/http/headers.rb#328
  def normalize_header(name); end

  # Ensures there is no new line character in the header value
  #
  # @api private
  # @param value [String]
  # @raise [HeaderError] if value includes new line character
  # @return [String] stringified header value
  #
  # source://http//lib/http/headers.rb#336
  def validate_value(value); end

  # Returns the wire name for a header
  #
  # @api private
  # @return [String]
  #
  # source://http//lib/http/headers.rb#316
  def wire_name_for(name, lookup_name); end

  class << self
    # Coerces given object into Headers
    #
    # @api public
    # @example
    #   headers = HTTP::Headers.coerce("Content-Type" => "text/plain")
    # @param object [#to_hash, #to_h, #to_a]
    # @raise [Error] if object can't be coerced
    # @return [Headers]
    #
    # source://http//lib/http/headers.rb#45
    def [](object); end

    # Coerces given object into Headers
    #
    # @api public
    # @example
    #   headers = HTTP::Headers.coerce("Content-Type" => "text/plain")
    # @param object [#to_hash, #to_h, #to_a]
    # @raise [Error] if object can't be coerced
    # @return [Headers]
    #
    # source://http//lib/http/headers.rb#25
    def coerce(object); end

    # Returns the shared normalizer instance
    #
    # @api public
    # @example
    #   HTTP::Headers.normalizer
    # @return [Headers::Normalizer]
    #
    # source://http//lib/http/headers.rb#54
    def normalizer; end
  end
end

